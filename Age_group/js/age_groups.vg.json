{
"$schema": "https://vega.github.io/schema/vega-lite/v5.json",
"title": { "text": "Number of new donors by age group" },
"width": 360,
"height": 297,
"padding": 20,
"data": {
  "url": "Age_group/data/age_group.csv"
  },
"layer": [
{
  "mark": "bar",
"encoding": {
  "x": { "field": "Age group", "type": "nominal" },
  "y": { "field": "Frequency", "type": "quantitative" },
  "color": {
    "condition": {
      "test": "datum['Age group'] === '17-24'",
      "value": "#ef4444"
      },
      "value": "lightgrey"
    },
  "tooltip": [
    {"field": "Age group", "type": "nominal"},
    {"field": "Frequency", "type": "quantitative"}
    ]
}
},

  {
    "mark": {
        "type": "text",
        "align": "left",
        "fontSize": 11,
        "lineBreak": "\n"
    },
    "encoding": {
        "x": {"value": 90},
        "y": {"value": 120},
        "text": {"value": "The highest number of donors are from\nthe 17-24 age group.\nThis infers that younger people are\nmore fitto donate their blood."},
        "color": {"value": "black"}}
    }]
}