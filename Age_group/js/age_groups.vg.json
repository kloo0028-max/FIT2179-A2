{
"$schema": "https://vega.github.io/schema/vega-lite/v5.json",
"title": { "text": "Number of new donors by age group" },
"width": 360,
"height": 320,
"data": {
  "url": "Age_group/data/age_group.csv"
  },
"mark": "bar",
"encoding": {
  "x": { "field": "Age group", "type": "nominal" },
  "y": { "field": "Frequency", "type": "quantitative" },
  "color": {
    "condition": {
      "test": "datum['Age group'] === '17-24'",
      "value": "#ef4444"
      },
      "value": "lightgrey"
    },
  "tooltip": [
    {"field": "Age group", "type": "nominal"},
    {"field": "Frequency", "type": "quantitative"}
    ]
}
}