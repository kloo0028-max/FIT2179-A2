{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "usermeta": {"embedOptions": {
  "renderer": "svg"
}},
  "title": {"text": "Number of new donors (2012-2025)", "font":"seriff", "fontSize": 15},
  "width": 630,
  "height": 380,

  "data": {"url": "New_donors/data/number of new donors.csv"},
  "layer": [
    {
      "mark": {"type": "line", "color": "black"},
      "encoding": {
        "x": {"field": "Year", "type": "nominal", "axis": {"labelAngle": 0}},
        "y": {"field": "Number of new donors", "type": "quantitative"},
        "tooltip": [
          {"field": "Year", "type": "nominal"},
          {"field": "Number of new donors", "type": "quantitative"}
        ]
      }
    },
    {
      "mark": {"type": "point", "dx": 10,"size": 80, "filled": true},
      "transform": [
        {"filter": "datum.Year == '2015' || datum.Year == '2021' || datum.Year == '2025'"}
      ],
      "encoding": {
        "x": {"field": "Year", "type": "nominal"},
        "y": {"field": "Number of new donors", "type": "quantitative"},
        "color": {
          "condition": {"test": "datum.Year == '2015'", "value": "red"},
          "value": "red"
        }
      }
    },
    {
      "mark": {"type": "text", "dx": -40, "dy": -5, "fontSize": 11, "fontWeight": "bold"},
      "transform": [
        {"filter": "datum.Year == '2015' || datum.Year == '2021' || datum.Year == '2025'"}
      ],
      "encoding": {
        "x": {"field": "Year", "type": "nominal"},
        "y": {"field": "Number of new donors", "type": "quantitative"},
        "text": {"field": "Number of new donors", "type": "quantitative", "format": ",.0f"},
        "color": {
          "condition": {"test": "datum.Year == '2015'", "value": "red"},
          "value": "red"
        }
      },
      "tooltip": [
        {"field": "Year", "type": "nominal"},
        {"field": "Number of new donors", "type": "quantitative"}
      ]
    },

    {
  "mark": {
        "type": "text",
        "align": "left",
        "fontSize": 13,
        "fontWeight":"lighter",
        "lineBreak": "\n"
    },
    "encoding": {
        "x": {"value": 20},
        "y": {"value": 160},
        "text": {"value": "The overall trend of the recruitment of new donors\nshows an overall decline over the years."},
        "color": {"value": "black"}}
    },
    
    {"mark": {
        "type": "text",
        "align": "right",
        "fontSize": 13,
        "fontWeight":"lighter",
        "lineBreak": "\n"
    },
    "encoding": {
        "x": {"value": 620},
        "y": {"value": 20},
        "text": {"value": "It is seen that due to the COVID-19 restrictions in 2021, donation\ncentres operated at reduced capacities nationwide."},
        "color": {"value": "black"}}
    }
  ]
}