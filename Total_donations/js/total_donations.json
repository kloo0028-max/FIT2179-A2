{
"$schema": "https://vega.github.io/schema/vega-lite/v5.json",
"title": { "text": "Total number of donations (2006-2026)" },
"data": {"url": "../data/total_donations_monthly.csv"},
"vconcat": [
{
"width": 600,
"height": 240,
"mark": "line",
"encoding": {
"x": {
    "field": "Month", 
    "type": "temporal",
    "scale": {"domain": {"param": "brush"}},
    "axis": {"title": ""}
    },
    "y": {"field": "Total donations", "type": "quantitative"}
}
},
{
"width": 600,
"height": 60,
"mark": "line",
"params": [
{"name": "brush", "select": {"type": "interval",
"encodings": ["x"]}}
],
"encoding": {
"x": {"field": "Month", "type": "temporal"},
"y": {
"field": "Total donations",
"type": "quantitative",
"axis": {"tickCount": 3, "grid": false}
}
}
}
]
}