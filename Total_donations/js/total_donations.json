{
"$schema": "https://vega.github.io/schema/vega-lite/v5.json",
"title": { "text": "Total number of donations (2006-2026)" },
"padding": 20,
"data": {"url": "Total_donations/data/total_donations_monthly.csv"},
"vconcat": [
{
"width": 1300,
"height": 280,
"mark": {"type": "line", "color": "#ef4444", "tooltip": true, "point": {"opacity": 0}},
"encoding": {
"x": {
    "field": "Month", 
    "type": "temporal",
    "scale": {"domain": {"param": "brush"}},
    "axis": {"title": ""}
    },
    "y": {"field": "Total donations", "type": "quantitative"},
    "tooltip": [
    {"field": "Month", "type": "temporal"},
    {"field": "Total donations", "type": "quantitative"}
    ]
}
},
{
"width": 1300,
"height": 150,
"mark": {"type": "line", "color": "#ef4444", "tooltip": true, "point": {"opacity": 0}},
"params": [
{"name": "brush", "select": {"type": "interval",
"encodings": ["x"]}}
],
"encoding": {
"x": {"field": "Month", "type": "temporal"},
"y": {
"field": "Total donations",
"type": "quantitative",
"axis": {"tickCount": 3, "grid": false}
}
}
}
]
}