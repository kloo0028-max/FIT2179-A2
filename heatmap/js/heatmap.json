{
    "$schema":"https://vega.github.io/schema/vega-lite/v6.json",
    "usermeta": {"embedOptions": {
        "renderer": "svg"
        }},
    "width": 600,
    "height": 298,
    "data": {
        "url": "heatmap/data/avg_donations_by_day.csv"
    },
    "title":{"text": "Blood Donation Patterns Across Months and Years (2020–2025)", "font": "seriff", "fontSize": 15},
    "config": {
        "view": {
        "strokeWidth": 0,
        "step": 13
    },
    "axis": {
        "domain": false
    }
    },
    "layer": [
    {
    "mark": {"type": "rect", "tooltip":true},
    "encoding": {
    "x": {
        "field": "Year",
        "type": "ordinal",
        "title": "Year",
        "axis": {
        "labelAngle": 0
        }
    },
    "y": {
        "field": "Month_Name",
        "type": "ordinal",
        "title": "Month",
        "sort": ["Jan","Feb","Mar","Apr","May","Jun",
        "Jul","Aug","Sep","Oct","Nov","Dec"]
    },
    "color": {
        "field": "Total_donations",
        "padding": 0,
        "type": "quantitative",
        "scale": {"scheme": "reds"},
        "legend": {
            "title": "Total donations",
            "orient": "bottom",
            "direction": "horizontal",
            "gradientLength": 600        }
      }
    }
}, 
{"mark": {
        "type": "text",
        "align": "left",
        "fontSize": 15,
        "fontWeight":"lighter",
        "lineBreak": "\n",
        "lineHeight": 25
    },
    "encoding": {
        "x": {"value": 610},
        "y": {"value": 20},
        "text": {"value": "Donations in\n2021 showed\nthe lowest\nvolumes\noverall,\nlikely due to\nthe COVID-19\ndisruptions.\nSince 2022, \nvolumes\nhave steadily\nrecovered\nand stabilised."},
        "color": {"value": "black"}}
    }]
}

