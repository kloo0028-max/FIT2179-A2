{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "usermeta": {"embedOptions": {
  "renderer": "svg"
}},
  "title": {"text": "Monthly Blood Donation Trends (2020–2025)", "font": "seriff", "fontSize": 15},
  "width": 650,
